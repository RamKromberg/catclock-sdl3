# 1. Global Default Configuration Block (Applies to all root C files)
BasedOnStyle: WebKit
SortIncludes: false
UseTab: Always
TabWidth: 4
IndentWidth: 4
ColumnLimit: 100
BreakBeforeBraces: Attach
SpaceAfterCStyleCast: true
AlignAfterOpenBracket: Align

---
# 2. Sub-Language Target Rule (Overrides configuration ONLY for GLSL/Cpp files)
Language: Cpp
# FIX 1: Stop reflowing and splitting Sokol @vs, @fs, and @program comment tags
ReflowComments: false
# FIX 2: Prevent aggressive line wrapping on dense shader vector calculations
ColumnLimit: 0
